{
  "id": "/app",
  "name": "FlexGym",
  "short_name": "FlexGym",
  "description": "Operacion diaria para gimnasios: clientes, membresias, caja y reportes.",
  "start_url": "/app?pwa_mode=standalone",
  "scope": "/",
  "display": "standalone",
